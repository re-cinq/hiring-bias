{
  "name": "hiring-bias",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "smoke": "node src/smokeTest.js",
    "generate": "node src/generateVariants.js",
    "run": "node src/runExperiment.js",
    "run:prompt-lab": "node scripts/runPromptLab.js",
    "build:prompt-lab": "node scripts/buildPromptLab.js",
    "run:transplant": "node scripts/runReasoningTransplant.js",
    "build:transplant": "node scripts/buildReasoningTransplant.js",
    "report": "node src/report.js",
    "build:matrix": "node scripts/buildSiteData.js",
    "build:synthesis": "node scripts/buildSynthesis.js",
    "build:site": "npm run build:matrix && npm run build:transplant && npm run build:prompt-lab && npm run build:synthesis",
    "serve": "npx --yes serve site -l 8080",
    "audit": "node scripts/auditDiffs.js",
    "audit:cli": "bash scripts/audit-diffs.sh"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@mistralai/mistralai": "^2.4.0",
    "dotenv": "^17.4.2",
    "openai": "^6.45.0",
    "p-limit": "^7.3.0"
  }
}
